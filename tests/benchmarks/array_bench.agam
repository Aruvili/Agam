இறக்குமதி "std/io";

செயல் மைய(): எண்64 {
    மாறி n: எண்64 = 5000000;
    மண்டலம் A {
        மாறி arr: *எண்64~A = ஒதுக்கீடு<எண்64>(n);
        மாறி நிலை total: எண்64 = 0;
        மாறி நிலை i: எண்64 = 0;
        
        வரை (i < n) {
            arr[i] = i * 2;
            i = i + 1;
        }
        
        i = 0;
        வரை (i < n) {
            total = total + arr[i];
            i = i + 1;
        }
        
        வரியிறக்கி_பதிப்பி(total);
    };
    விடை 0;
}
