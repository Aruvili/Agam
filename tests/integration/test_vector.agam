இறக்குமதி "../../std/io.agam";
இறக்குமதி "../../std/collections.agam";

செயல் மைய(): எண்64 {
    மாறி நிலை v: நெறியம்<எண்64> = புதிய_நெறியம்<எண்64>();
    
    // பல விரிவாக்கங்களுடன் செருகுவதை சோதிக்கிறோம்
    மாறி நிலை இ: எண்64 = 0;
    வரை (இ < 20) {
        (&v).செருகு(இ * 10);
        இ = இ + 1;
    }
    
    வரியிறக்கி_பதிப்பி("நெறியத்தின் நீளம்: %d", (&v).நீளம்());
    வரியிறக்கி_பதிப்பி("நெறியத்தின் கொள்ளளவு: %d", (&v).கொள்ளளவு());
    
    // பெறுதலை சோதிக்கிறோம்
    மாறி மதிப்பு5: எண்64 = (&v).பெறு(5);
    மாறி மதிப்பு15: எண்64 = (&v).பெறு(15);
    
    எனில் (மதிப்பு5 == 50 && மதிப்பு15 == 150 && (&v).நீளம்() == 20) {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் செருகுதல் மற்றும் பெறுதல் சரியாக உள்ளது!");
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் செருகுதல் மற்றும் பெறுதல் தோல்வியுற்றது!");
        விடை 1;
    }
    
    // கடைசி உறுப்பை நீக்குவதை சோதிக்கிறோம்
    மாறி கடைசி: எண்64 = (&v).நீக்கு_கடைசி();
    எனில் (கடைசி == 190 && (&v).நீளம்() == 19) {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் நீக்கு_கடைசி சரியாக உள்ளது!");
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் நீக்கு_கடைசி தோல்வியுற்றது!");
        விடை 1;
    }
    
    // அமைத்தலை சோதிக்கிறோம்
    (&v).அமை(0, 999);
    எனில் ((&v).பெறு(0) == 999) {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் அமைத்தல் சரியாக உள்ளது!");
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் அமைத்தல் தோல்வியுற்றது!");
        விடை 1;
    }
    
    // நினைவகத்தை விடுவிப்பதை சோதிக்கிறோம்
    (&v).விடுவி();
    எனில் ((&v).நீளம்() == 0) {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் விடுவித்தல் சரியாக உள்ளது!");
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் விடுவித்தல் தோல்வியுற்றது!");
        விடை 1;
    }
    
    வரியிறக்கி_பதிப்பி("அனைத்து நெறியம் சோதனைகளும் வெற்றி!");
    விடை 0;
}
