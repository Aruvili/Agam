இறக்குமதி "../../std/io.agam";

அமைப்பு Counter {
    value: எண்64
}

செயல்படுத்து *Counter {
    செயல் inc(நிலை தன்னிலை: *Counter): வெற்று {
        தன்னிலை.value = தன்னிலை.value + 1;
    }

    செயல் get(தன்னிலை: Counter): எண்64 {
        விடை தன்னிலை.value;
    }
}

செயல் மைய(): எண்64 {
    மாறி நிலை c: Counter = Counter { value: 10 };
    (&c).inc();
    (&c).inc();
    
    எனில் ((&c).get() == 12) {
        வரியிறக்கி_பதிப்பி("Inherent methods work!");
        விடை 0;
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("Inherent methods failed!");
        விடை 1;
    }
}
