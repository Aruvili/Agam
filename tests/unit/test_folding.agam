இறக்குமதி "std/io";

செயல் மைய(): எண் {
    மாறி x: எண் = 10 + 20 * 2; // Should fold to 50
    மாறி y: எண் = 100 / 2 - 5;  // Should fold to 45
    மாறி z: மெய்மை = (x == 50) && (y != 0); // Should fold to உண்மை
    
    எனில் (z) {
        வரியிறக்கி_பதிப்பி(x + y); // Should பதிப்பி 95
    }
    
    விடை 0;
}
