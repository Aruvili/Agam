இறக்குமதி "std/io";

செயல் மைய(): வெற்று {
    மண்டலம் A {
        மாறி x: *எண்32~A = ஒதுக்கீடு<எண்32>(5);
        
        கடன் பகிர்வு(x) ஆக view;
        
        மண்டலம் B {
            மாறி y: *எண்32~B = ஒதுக்கீடு<எண்32>(1);
            
            மாறி escaped_y: *எண்32~A = தப்பித்தல்(y) -> A;
        };
    };
    
    பதிப்பி("ZPM Syntax Test Passed\n");
}
