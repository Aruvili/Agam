        },
        {
          "name": "support.type.agam",
          "match": "\\b(Я«јЯ«БЯ»Ї|Я«цЯ«џЯ««Я««Я»Ї32|Я«цЯ«џЯ««Я««Я»Ї64|Я«џЯ«░Я««Я»Ї|Я««Я»єЯ«»Я»Ї|Я«хЯ»єЯ«▒Я»ЂЯ««Я»ѕ|Я«џЯ»ЂЯ«»)\\b"
        },
        {
          "name": "constant.language.agam",
          "match": "\\b(Я«ЅЯ«БЯ»ЇЯ««Я»ѕ|Я«фЯ»іЯ«»Я»Ї|Я«ЄЯ«▓Я»ЇЯ«▓Я»ѕ)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.agam",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.agam",
          "match": "\\\\."
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.agam",
          "match": "#.*$"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.agam",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    }
  },
  "scopeName": "source.agam"
}
