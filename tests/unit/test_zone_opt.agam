இறக்குமதி "../../std/io.agam";

செயல் மைய(): எண் {
    மண்டலம் அ_வலயம் {
        மாறி அ: *எண்~அ_வலயம் = ஒதுக்கீடு<எண்>(1);
        மாறி ஆ: *எண்~அ_வலயம் = ஒதுக்கீடு<எண்>(1);
        மாறி இ: *எண்~அ_வலயம் = ஒதுக்கீடு<எண்>(1);
        
        நெறிய_ptr_அமை(அ, 0, 10);
        நெறிய_ptr_அமை(ஆ, 0, 20);
        நெறிய_ptr_அமை(இ, 0, 30);
        
        மாறி மொத்தம்: எண் = நெறிய_ptr_பெறு(அ, 0) + நெறிய_ptr_பெறு(ஆ, 0) + நெறிய_ptr_பெறு(இ, 0);
        பதிப்பி("மொத்தம்: ");
        வரியிறக்கி_பதிப்பி(மொத்தம்);
    };
    விடை 0;
}

செயல் நெறிய_ptr_அமை(ப: *எண், சுட்டு: எண், மதிப்பு: எண்): வெற்று {
    ப[சுட்டு] = மதிப்பு;
}

செயல் நெறிய_ptr_பெறு(ப: *எண், சுட்டு: எண்): எண் {
    விடை ப[சுட்டு];
}
