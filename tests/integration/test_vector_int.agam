இறக்குமதி "../../std/io.agam";

அமைப்பு நெறியம்_எண்64 {
    தரவு: &[எண்64],
    நீளம்: எண்64
}

செயல்படுத்து *நெறியம்_எண்64 {
    செயல் கொள்ளளவு(தன்னிலை: *நெறியம்_எண்64): எண்64 {
        விடை தன்னிலை.தரவு.len;
    }

    செயல் நீளம்(தன்னிலை: *நெறியம்_எண்64): எண்64 {
        விடை தன்னிலை.நீளம்;
    }

    செயல் வெற்று_நிலை(தன்னிலை: *நெறியம்_எண்64): மெய்மை {
        விடை தன்னிலை.நீளம் == 0;
    }

    செயல் ஒதுக்கு(நிலை தன்னிலை: *நெறியம்_எண்64, புதிய_கொள்ளளவு: எண்64): வெற்று {
        எனில் (புதிய_கொள்ளளவு <= தன்னிலை.தரவு.len) {
            விடை;
        }

        மாறி புதிய_தாங்குதளம்: &[எண்64] = புதிய [எண்64; புதிய_கொள்ளளவு];
        மாறி புதிய_தரவு: *எண்64 = புதிய_தாங்குதளம்.data;

        எனில் (தன்னிலை.நீளம் > 0) {
            மாறி நிலை இ: எண்64 = 0;
            மாறி பழைய_தரவு: *எண்64 = தன்னிலை.தரவு.data;
            வரை (இ < தன்னிலை.நீளம்) {
                புதிய_தரவு[இ] = பழைய_தரவு[இ];
                இ = இ + 1;
            }
            நீக்கு பழைய_தரவு;
        }

        தன்னிலை.தரவு = புதிய_தாங்குதளம்;
    }

    செயல் விரிவாக்கு(நிலை தன்னிலை: *நெறியம்_எண்64): வெற்று {
        மாறி நிலை புதிய_கொள்ளளவு: எண்64 = 0;
        எனில் (தன்னிலை.தரவு.len == 0) {
            புதிய_கொள்ளளவு = 8;
        } இல்லையெனில் {
            புதிய_கொள்ளளவு = தன்னிலை.தரவு.len * 2;
        }
        தன்னிலை.ஒதுக்கு(புதிய_கொள்ளளவு);
    }

    செயல் செருகு(நிலை தன்னிலை: *நெறியம்_எண்64, மதிப்பு: எண்64): வெற்று {
        எனில் (தன்னிலை.நீளம் == தன்னிலை.தரவு.len) {
            தன்னிலை.விரிவாக்கு();
        }
        தன்னிலை.தரவு[தன்னிலை.நீளம்] = மதிப்பு;
        தன்னிலை.நீளம் = தன்னிலை.நீளம் + 1;
    }

    செயல் பெறு(தன்னிலை: *நெறியம்_எண்64, சுட்டு: எண்64): எண்64 {
        எனில் (சுட்டு >= தன்னிலை.நீளம்) {
            வரியிறக்கி_பதிப்பி("பிழை: எல்லையை மீறிய சுட்டு!");
            விடை 0;
        }
        விடை தன்னிலை.தரவு[சுட்டு];
    }

    செயல் அமை(நிலை தன்னிலை: *நெறியம்_எண்64, சுட்டு: எண்64, மதிப்பு: எண்64): வெற்று {
        எனில் (சுட்டு >= தன்னிலை.நீளம்) {
            வரியிறக்கி_பதிப்பி("பிழை: எல்லையை மீறிய சுட்டு!");
            விடை;
        }
        தன்னிலை.தரவு[சுட்டு] = மதிப்பு;
    }

    செயல் நீக்கு_கடைசி(நிலை தன்னிலை: *நெறியம்_எண்64): எண்64 {
        எனில் (தன்னிலை.நீளம் == 0) {
            வரியிறக்கி_பதிப்பி("பிழை: நெறியம் காலியாக உள்ளது!");
            விடை 0;
        }
        தன்னிலை.நீளம் = தன்னிலை.நீளம் - 1;
        விடை தன்னிலை.தரவு[தன்னிலை.நீளம்];
    }

    செயல் விடுவி(நிலை தன்னிலை: *நெறியம்_எண்64): வெற்று {
        எனில் (தன்னிலை.தரவு.len > 0) {
            மாறி பழைய_தரவு: *எண்64 = தன்னிலை.தரவு.data;
            நீக்கு பழைய_தரவு;
            தன்னிலை.தரவு = புதிய [எண்64; 0];
            தன்னிலை.நீளம் = 0;
        }
    }
}

செயல் புதிய_நெறியம்_எண்64(): நெறியம்_எண்64 {
    விடை நெறியம்_எண்64 {
        தரவு: புதிய [எண்64; 0],
        நீளம்: 0
    };
}

செயல் மைய(): எண்64 {
    மாறி நிலை v: நெறியம்_எண்64 = புதிய_நெறியம்_எண்64();
    
    மாறி நிலை இ: எண்64 = 0;
    வரை (இ < 20) {
        (&v).செருகு(இ * 10);
        இ = இ + 1;
    }
    
    வரியிறக்கி_பதிப்பி("நெறியத்தின் நீளம்: %d", (&v).நீளம்());
    வரியிறக்கி_பதிப்பி("நெறியத்தின் கொள்ளளவு: %d", (&v).கொள்ளளவு());
    
    மாறி மதிப்பு5: எண்64 = (&v).பெறு(5);
    மாறி மதிப்பு15: எண்64 = (&v).பெறு(15);
    
    எனில் (மதிப்பு5 == 50 && மதிப்பு15 == 150 && (&v).நீளம்() == 20) {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் செருகுதல் மற்றும் பெறுதல் சரியாக உள்ளது!");
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் செருகுதல் மற்றும் பெறுதல் தோல்வியுற்றது!");
        விடை 1;
    }
    
    மாறி கடைசி: எண்64 = (&v).நீக்கு_கடைசி();
    எனில் (கடைசி == 190 && (&v).நீளம்() == 19) {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் நீக்கு_கடைசி சரியாக உள்ளது!");
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் நீக்கு_கடைசி தோல்வியுற்றது!");
        விடை 1;
    }
    
    (&v).அமை(0, 999);
    எனில் ((&v).பெறு(0) == 999) {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் அமைத்தல் சரியாக உள்ளது!");
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் அமைத்தல் தோல்வியுற்றது!");
        விடை 1;
    }
    
    (&v).விடுவி();
    எனில் ((&v).நீளம்() == 0) {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் விடுவித்தல் சரியாக உள்ளது!");
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("நெறியத்தின் விடுவித்தல் தோல்வியுற்றது!");
        விடை 1;
    }
    
    வரியிறக்கி_பதிப்பி("அனைத்து நெறியம் சோதனைகளும் வெற்றி!");
    விடை 0;
}
