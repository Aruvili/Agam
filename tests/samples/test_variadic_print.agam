இறக்குமதி "../../std/io.agam";

செயல் மைய(): எண் {
    மாறி name: சரம் = "Agam";
    மாறி version: தசமம்64 = 0.1;
    மாறி is_awesome: மெய்மை = உண்மை;

    பதிப்பி("Project: ");
    பதிப்பி(name);
    பதிப்பி(", version: ");
    பதிப்பி(version);
    பதிப்பி(", awesomeness: ");
    வரியிறக்கி_பதிப்பி(is_awesome);

    விடை 0;
}