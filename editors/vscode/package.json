{
  "name": "agam-vscode",
  "displayName": "Agam",
  "description": "Tamil Programming Language Support (Agam)",
  "version": "1.2.0",
  "publisher": "Aruvili",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:agam"
  ],
  "contributes": {
    "languages": [
      {
        "id": "agam",
        "aliases": ["Agam", "agam"],
        "extensions": [".agam"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "agam",
        "scopeName": "source.agam",
        "path": "./syntaxes/agam.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Agam",
      "properties": {
        "agam.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the agam-lsp.exe executable. If left empty, it will look in the default workspace build/bin folder."
        }
      }
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}
