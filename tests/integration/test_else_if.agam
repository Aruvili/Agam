இறக்குமதி "../../std/io.agam";

செயல் மைய(): எண் {
    மாறி x: எண் = 7;
    எனில் (x == 5) {
        வரியிறக்கி_பதிப்பி("x is 5");
    } இல்லையெனில் எனில் (x <= 9) {
        வரியிறக்கி_பதிப்பி("x is less than or equal to 9");
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("x is greater than 9");
    }

    // Nested Twist
    மாறி y: எண் = 15;
    எனில் (y < 10) {
        வரியிறக்கி_பதிப்பி("y < 10");
    } இல்லையெனில் எனில் (y < 20) {
        எனில் (y == 15) {
            வரியிறக்கி_பதிப்பி("y is exactly 15");
        } இல்லையெனில் {
            வரியிறக்கி_பதிப்பி("y is between 10 and 20 but not 15");
        }
    } இல்லையெனில் {
        வரியிறக்கி_பதிப்பி("y >= 20");
    }

    விடை 0;
}
