இறக்குமதி "std/math";
இறக்குமதி "std/io";

செயல் மைய(): எண் {
    மாறி limit: எண் = 20000;
    மாறி நிலை count: எண் = 0;
    மாறி நிலை num: எண் = 2;
    
    வரை (num < limit) {
        மாறி நிலை is_prime: மெய்மை = உண்மை;
        மாறி நிலை i: எண் = 2;
        மாறி max_i: எண் = வர்க்கமூலம்(num ஆக தசமம்64) ஆக எண்;
        
        வரை (i <= max_i) {
            எனில் (num % i == 0) {
                is_prime = பொய்;
                i = max_i; // Early exit strategy
            }
            i = i + 1;
        }
        
        எனில் (is_prime) {
            count = count + 1;
        }
        num = num + 1;
    }
    
    வரியிறக்கி_பதிப்பி(count);
    விடை 0;
}
