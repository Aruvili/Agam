// Control flow: எனில்/இல்லையெனில் and வரை loops
செயல் abs(x: எண்): எண் {
    எனில் (x < 0) {
        விடை -x;
    }
    விடை x;
}

செயல் factorial(n: எண்): எண் {
    மாறி நிலை result: எண் = 1;
    மாறி நிலை i: எண் = 1;
    வரை (i <= n) {
        result = result * i;
        i = i + 1;
    }
    விடை result;
}

செயல் மைய(): எண் {
    மாறி a: எண் = abs(-5);
    மாறி b: எண் = factorial(5);
    எனில் (a == 5) {
        விடை b;
    } இல்லையெனில் {
        விடை 0;
    }
}
